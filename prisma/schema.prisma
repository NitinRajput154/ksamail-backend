// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String
  username      String    @unique
  email         String    @unique
  phone         String?
  recoveryEmail String?
  password      String
  phoneVerified Boolean   @default(false)
  emailVerified Boolean   @default(false)
  role          String    @default("USER")
  mailboxes     Mailbox[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Mailbox {
  id        String   @id @default(uuid())
  email     String   @unique
  quota     Int      @default(1024) // Quota in MB
  status    String   @default("active")
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
}

model OtpSession {
  id        String   @id @default(uuid())
  target    String   // phone number or email address
  type      String   @default("phone") // "phone" or "email"
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([target, type])
}

model PasswordResetSession {
  id             String    @id @default(uuid())
  email          String    // The KSA Mail email of the user requesting the reset
  target         String    // Recovery email or phone where OTP was sent
  method         String    @default("email") // "email" or "phone"
  verified       Boolean   @default(false)
  resetToken     String?   @unique // Short-lived token issued after OTP verification
  attempts       Int       @default(0)
  expiresAt      DateTime
  tokenExpiresAt DateTime? // When the reset token expires (after OTP verified)
  createdAt      DateTime  @default(now())

  @@index([email])
  @@index([resetToken])
}

model Banner {
  id          String   @id @default(uuid())
  title       String
  subtitle    String?
  buttonText  String   @default("Learn More")
  buttonLink  String   @default("/signup")
  image       String   // Filename or URL
  bgColor     String   @default("linear-gradient(135deg, rgba(10, 88, 50, 0.82) 0%, rgba(13, 110, 63, 0.75) 100%)")
  isActive    Boolean  @default(true)
  order       Int      @default(0) // For sorting
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
